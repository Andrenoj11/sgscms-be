APP_NAME=SGS CMS API
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sgscms
DB_USER=sgscms
DB_PASSWORD=your_database_password
DB_SSL_MODE=disable
DB_TIMEZONE=Asia/Jakarta

SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_password

JWT_SECRET=replace_with_a_random_secret_at_least_32_characters
JWT_ISSUER=sgscms-api
JWT_ACCESS_TTL=15m

UPLOAD_DIRECTORY=uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads
UPLOAD_MAX_IMAGE_SIZE=2097152

JWT_REFRESH_TTL=168h

SIGNATURE_ENCRYPTION_KEY=replace_with_base64_32_byte_key
SIGNATURE_MAX_AGE=5m

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=1m