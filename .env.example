APP_ENV=development
HTTP_ADDR=:8080
DATABASE_URL=postgres://sgscms:sgscms@localhost:5432/sgscms?sslmode=disable
SESSION_TTL=12h
SESSION_COOKIE_NAME=sgscms_session
SESSION_SECURE=false
MAX_UPLOAD_BYTES=10485760
MAX_IMAGE_WIDTH=8000
MAX_IMAGE_HEIGHT=8000
PUBLIC_BASE_URL=http://localhost:8080
MEDIA_DIR=./var/media
# Leave S3_ENDPOINT empty to use local development storage.
S3_ENDPOINT=
S3_BUCKET=sgscms-media
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=ap-southeast-3
S3_USE_SSL=true
S3_PUBLIC_URL=
SIGNATURE_TOLERANCE=5m
API_CLIENT_ENCRYPTION_KEY=development-only-change-me
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=change-me-now
