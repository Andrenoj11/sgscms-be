# =========================================================
# Application
# =========================================================

APP_NAME=SGS CMS API
APP_ENV=development
APP_PORT=8080
APP_DEBUG=true

APP_EXPOSED_PORT=8080

# =========================================================
# HTTP server
# =========================================================

SERVER_READ_TIMEOUT=15s
SERVER_READ_HEADER_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=10s

SERVER_MAX_JSON_BODY_SIZE=1048576

TRUSTED_PROXIES=

# =========================================================
# Database
# =========================================================

DB_HOST=localhost
DB_PORT=5432
DB_EXPOSED_PORT=5432

DB_NAME=sgscms
DB_USER=sgscms
DB_PASSWORD=ganti_dengan_password_database
DB_SSL_MODE=disable
DB_TIMEZONE=Asia/Jakarta
DB_QUERY_EXEC_MODE=cache_statement
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=10

# =========================================================
# Admin seed
# =========================================================

SEED_ADMIN_NAME=Super Admin
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=ganti_dengan_password_admin

# =========================================================
# JWT
# =========================================================

JWT_SECRET=ganti_dengan_secret_minimal_32_karakter
JWT_ISSUER=sgscms-api
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# =========================================================
# Request signature
# =========================================================

SIGNATURE_ENCRYPTION_KEY=ganti_dengan_base64_32_byte
SIGNATURE_MAX_AGE=5m

# =========================================================
# CORS
# =========================================================

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# =========================================================
# Login rate limit
# =========================================================

LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=1m

# =========================================================
# Upload
# =========================================================

STORAGE_DRIVER=local
UPLOAD_DIRECTORY=uploads
UPLOAD_BASE_URL=http://localhost:8080/uploads
UPLOAD_MAX_IMAGE_SIZE=2097152

# Required only when STORAGE_DRIVER=supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=cms-images
